-void HNSWIndexScan::LoadIndex(const std::string &p_path,
+// DEV-1235 (ADR-0009 rebuild-on-recovery): state struct threaded through the
+// heap-rebuild scan callback. Mirrors HNSWIndexBuilder but inline here to avoid
+// pulling in hnswindex_builder.hpp (that header exposes ambuild internals).
+struct HNSWRebuildState
+{
+    std::shared_ptr<hnswlib::HierarchicalNSW<float>> vector_index;
+    int dim;
+    int tuples_added;
+};
+
+// DEV-1235 (ADR-0009 rebuild-on-recovery): heap-scan callback for LoadIndex
+// rebuild. Mirrors HNSWLoadTupleCallback in hnswindex_builder.cpp exactly:
+//   label = (blockId << 32) | offset  — the same encoding hnsw_insert uses.
+// hnswlib::addPoint is idempotent on duplicate labels (updates the existing
+// entry rather than inserting a duplicate), so if aminsert's own-transaction
+// in-progress row is seen by SnapshotAny during rebuild AND addPoint is called
+// again by aminsert afterwards, the second call is a no-op vector update with
+// identical data — no duplicate node, no corruption (DEV-1235 subtlety 1).
+static void
+HNSWRebuildCallback(Relation /*index*/,
+                    ItemPointer tid,
+                    Datum *values,
+                    bool *isnull,
+                    bool tupleIsAlive,
+                    void *state)
+{
+    // Only index live tuples. RECENTLY_DEAD tuples are passed by SnapshotAny
+    // but we intentionally skip them: they are dead for MVCC purposes and a
+    // crash-recovered index need not serve them. tupleIsAlive is false for
+    // RECENTLY_DEAD in the SnapshotAny path (heapam_handler.c:1406).
+    if (!tupleIsAlive)
+        return;
+
+    if (*isnull)
+        return;
+
+    HNSWRebuildState &self = *reinterpret_cast<HNSWRebuildState *>(state);
+    Datum value = values[0];
+
+    auto array = convert_array_to_vector(value);
+    if (static_cast<int>(array.size()) != self.dim)
+    {
+        ereport(ERROR,
+                (errcode(ERRCODE_DATA_EXCEPTION),
+                 errmsg("DEV-1235 rebuild: inconsistent array length, expected %d, found %zu",
+                        self.dim, array.size())));
+    }
+
+    std::int32_t blockId = ItemPointerGetBlockNumberNoCheck(tid);
+    std::int32_t offset  = ItemPointerGetOffsetNumberNoCheck(tid);
+    std::uint64_t number = static_cast<std::uint64_t>(blockId);
+    number = (number << 32) + static_cast<std::uint64_t>(offset);
+
+    self.vector_index->addPoint(reinterpret_cast<char *>(array.data()), number);
+    self.tuples_added++;
+}
+
+// DEV-1235 (ADR-0009 rebuild-on-recovery): LoadIndex now takes the index
+// Relation and rebuilds the in-RAM HierarchicalNSW from the WAL-durable HEAP
+// on cache-miss, instead of loading the stale ambuild flat file. The heap is
+// the source of truth; the flat file is left untouched but is no longer used
+// for loading after this patch. Cached in vector_index_map after first build —
+// O(heap) cost at most once per backend per index.
+//
+// Snapshot / visibility: table_index_build_scan with scan=NULL uses SnapshotAny
+// (ii_Concurrent=false, non-bootstrap) which calls HeapTupleSatisfiesVacuum.
+// HEAPTUPLE_DEAD tuples (aborted or vacuumable) yield tupleIsAlive=false and
+// are skipped in HNSWRebuildCallback — satisfying oracle C (abort exclusion).
+// HEAPTUPLE_LIVE tuples are indexed. HEAPTUPLE_INSERT_IN_PROGRESS tuples from
+// the current transaction (the aminsert case) are also indexed with
+// tupleIsAlive=true — this is correct: hnswlib::addPoint is idempotent on
+// duplicate labels, so the subsequent aminsert addPoint is harmless.
+//
+// Cross-session correctness (oracle B): the rebuild happens at first-access
+// in each backend, scanning all committed heap rows, so a row committed by
+// backend1 is visible to backend2's rebuild scan.
+// TRIDB: HNSW rebuild-on-recovery (DEV-1235)
+void HNSWIndexScan::LoadIndex(Relation index,
+                              const std::string &p_path,
                               DistanceMethod distance_method,
                               int dim)
 {
-    if(vector_index_map.find(p_path)==vector_index_map.end())
+    // Cache guard: at most once per backend per index path.
+    if (vector_index_map.find(p_path) != vector_index_map.end())
+        return;
+
+    // Build the distance space (same as ConstructInternalBuilder).
+    std::shared_ptr<hnswlib::SpaceInterface<float>> distanceFunction;
+    switch (distance_method)
     {
-        std::shared_ptr<hnswlib::SpaceInterface<float>> distanceFunction;
-        switch (distance_method)
-        {
-        case DistanceMethod::L2:
-            distanceFunction = std::make_shared<hnswlib::L2Space>(dim);
-            break;
-        case DistanceMethod::InnerProduct:
-            distanceFunction = std::make_shared<hnswlib::InnerProductSpace>(dim);
-            break;
-        default:
-            exit(1);
-        }
-        auto vector_index = std::make_shared<hnswlib::HierarchicalNSW<float>>(
-            distanceFunction.get(), p_path);
-        distanceFunction_map.insert(std::make_pair(p_path,distanceFunction));
-        vector_index_map.insert(std::make_pair(p_path,vector_index));
+    case DistanceMethod::L2:
+        distanceFunction = std::make_shared<hnswlib::L2Space>(dim);
+        break;
+    case DistanceMethod::InnerProduct:
+        distanceFunction = std::make_shared<hnswlib::InnerProductSpace>(dim);
+        break;
+    default:
+        ereport(ERROR,
+                (errcode(ERRCODE_DATA_EXCEPTION),
+                 errmsg("DEV-1235 LoadIndex: unknown distance method")));
     }
+
+    // Derive heap OID from the index relation. IndexGetRelation(oid, missing_ok).
+    Oid heapOid = IndexGetRelation(RelationGetRelid(index), false);
+    Relation heap = table_open(heapOid, AccessShareLock);
+
+    // Capacity estimate: use pg_class.reltuples * 10 (same factor as
+    // ConstructInternalBuilder). reltuples may be 0 (no ANALYZE / fresh table)
+    // or -1 (PG 13 "statistics never collected" sentinel). A negative double
+    // cast to size_t wraps to a huge value -> giant malloc -> NULL -> crash, so
+    // only multiply when positive; otherwise floor at 16 (HierarchicalNSW grows
+    // on demand past the initial capacity).
+    double reltuples = heap->rd_rel->reltuples;
+    size_t capacity = (reltuples > 0.0)
+                          ? static_cast<size_t>(reltuples * 10.0)
+                          : 16;
+    if (capacity < 16)
+        capacity = 16;
+
+    auto vector_index =
+        std::make_shared<hnswlib::HierarchicalNSW<float>>(distanceFunction.get(), capacity);
+
+    // Build IndexInfo for table_index_build_scan. BuildIndexInfo reads the
+    // index catalog (expression trees, predicate, etc.) — we need it even
+    // though our callback ignores predicates, because the scan API requires it.
+    IndexInfo *indexInfo = BuildIndexInfo(index);
+
+    HNSWRebuildState state;
+    state.vector_index  = vector_index;
+    state.dim           = dim;
+    state.tuples_added  = 0;
+
+    // table_index_build_scan with scan=NULL: the heap AM picks SnapshotAny
+    // (non-concurrent, non-bootstrap) and calls HeapTupleSatisfiesVacuum on
+    // each tuple. Dead/aborted tuples are skipped (tupleIsAlive=false). The
+    // callback adds only live tuples to the in-RAM index.
+    //
+    // Notes (Linus review):
+    //  - If a concurrent DELETE is in progress on the heap during rebuild, the
+    //    heap AM emits a WARNING "concurrent delete in progress" and the tuple
+    //    is correctly excluded (tupleIsAlive=false). Expected under load; not a bug.
+    //  - If HNSWRebuildCallback ereport(ERROR)s (e.g. dimension mismatch), the
+    //    longjmp skips table_close below; the AccessShareLock is still released by
+    //    the lock manager at transaction abort (not by table_close), and the
+    //    half-built HierarchicalNSW leaks until backend exit. No map entry is
+    //    cached, so the next LoadIndex retries cleanly. Acceptable for v1.
+    //  - Known v1 gap (ADR-0009 Phase C): a row whose concurrent DELETE is
+    //    in-progress at rebuild time is excluded; if that delete later ABORTS, the
+    //    still-live row is missing from this backend's index until its next rebuild.
+    table_index_build_scan(heap,
+                           index,
+                           indexInfo,
+                           false,   /* allow_sync: false — no syncscan needed */
+                           false,   /* progress: no PROGRESS_SCAN_BLOCKS_* updates */
+                           HNSWRebuildCallback,
+                           reinterpret_cast<void *>(&state),
+                           NULL);   /* scan: NULL — let heap AM create with SnapshotAny */
+
+    table_close(heap, AccessShareLock);
+
+    // Cache: both maps must be populated together so distanceFunction lifetime
+    // is tied to vector_index (hnswlib holds a raw pointer to the space object).
+    distanceFunction_map.insert(std::make_pair(p_path, distanceFunction));
+    vector_index_map.insert(std::make_pair(p_path, vector_index));
 }
 
