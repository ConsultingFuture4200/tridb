+inline float castAttrToFloatT(TupleTableSlot *slot, int attno){
+	bool isNull;
+	Datum value = slot_getattr(slot, attno, &isNull);
+	float retval = 0;
+
+	if ( isNull)
+		return 0;
+
+	TupleDesc tupdesc = slot->tts_tupleDescriptor;
+	Form_pg_attribute attr = TupleDescAttr(tupdesc, attno-1);
+	switch (attr->atttypid)	 {
+	case INT4OID:
+		retval = (float)DatumGetInt32(value);
+		break;
+	case INT8OID:
+		retval = (float)DatumGetInt64(value);
+		break;
+	case FLOAT8OID:
+		retval = (float)DatumGetFloat8(value);
+		break;
+	default:
+		elog(ERROR, "castAttrToFloatT unsupported oid = %d", attr->atttypid);
+	}
+	return retval;
+}
+
+// Read attribute `attno` (1-based) of `slot` as an int64 — the candidate's graph vertex id, used
+// for the reachability predicate. NULL ids can never be reachable, so they are reported as such.
+inline bool getAttrAsInt64T(TupleTableSlot *slot, int attno, int64 *out){
+	bool isNull;
+	Datum value = slot_getattr(slot, attno, &isNull);
+	if (isNull)
+		return false;
+
+	TupleDesc tupdesc = slot->tts_tupleDescriptor;
+	Form_pg_attribute attr = TupleDescAttr(tupdesc, attno-1);
+	switch (attr->atttypid) {
+	case INT4OID:
+		*out = (int64) DatumGetInt32(value);
+		return true;
+	case INT8OID:
+		*out = DatumGetInt64(value);
+		return true;
+	default:
+		elog(ERROR, "TJS graph predicate: candidate id column must be int4/int8, got oid = %d",
+			 attr->atttypid);
+	}
+	return false;
+}
+
+inline Oid getrelidT(const std::string relname){
+	char cmd[256];
+	int cmd_len = snprintf(cmd, sizeof(cmd), "SELECT oid FROM pg_catalog.pg_class WHERE relname = '%s';", relname.c_str());
+	if ( cmd_len < 0 ) {
+		elog(ERROR, "getrelidT:: relname '%s' is too long", relname.c_str());
+		return InvalidOid;
+	}
+	SPI_connect();
+	int ret = SPI_exec(cmd, 1);
+	uint64 proc = SPI_processed;
+	Oid retval = InvalidOid;
+	if ( ret > 0 && SPI_tuptable != NULL ){
+		TupleDesc tupdesc = SPI_tuptable->tupdesc;
+		SPITupleTable *tuptable = SPI_tuptable;
+		if ( proc > 1 )
+			ereport(ERROR, (errcode(ERRCODE_DATA_EXCEPTION), errmsg("only a single relname should be returned")));
+		if ( tupdesc->natts != 1 )
+			ereport(ERROR, (errcode(ERRCODE_DATA_EXCEPTION), errmsg("only a single attribute should be returned")));
+		if ( proc == 1 ) {
+			HeapTuple tuple = tuptable->vals[0];
+			bool isnull;
+			Datum value = SPI_getbinval(tuple, tupdesc, 1, &isnull);
+			if ( isnull )
+				ereport(ERROR, (errcode(ERRCODE_DATA_EXCEPTION), errmsg("Non-null value should be returned")));
+			retval = DatumGetObjectId(value);
+		} else {
+			elog(ERROR, "getrelidT:: cannot find relid for relname (%s)", relname.c_str());
+		}
+	}
+	SPI_finish();
+	return retval;
+}
+
+// DFS for the IndexScanState / IndexScan nodes — identical to multicol_topk's, renamed.
+IndexScanState* findIndexScanStateT(PlanState* node){
+	if (!node) return NULL;
+	if (nodeTag(node) == T_IndexScanState) return (IndexScanState*)node;
+	IndexScanState* r = findIndexScanStateT(outerPlanState(node));
+	if (r) return r;
+	return findIndexScanStateT(innerPlanState(node));
+}
+
+IndexScan* findIndexScanNodeT(Plan* node){
+	if (!node) return NULL;
+	if (nodeTag(node) == T_IndexScan) return (IndexScan*)node;
+	IndexScan* r = findIndexScanNodeT(outerPlan(node));
+	if (r) return r;
+	return findIndexScanNodeT(innerPlan(node));
+}
+
+PlannedStmt* extractIndexScanNodeT(char* query){
+	CachedPlan *cplan = NULL;
+	bool old_enable_seqscan = enable_seqscan;
+	enable_seqscan = false;
+	PlannedStmt* plan = NULL;
+	SPIPlanPtr planptr = SPI_prepare(query, 0, NULL);
+	cplan = SPI_plan_get_cached_plan(planptr);
+	List* stmt_list = cplan->stmt_list;
+	ListCell* lc;
+	IndexScan* node = NULL;
+	foreach(lc, stmt_list){
+		PlannedStmt *stmt = lfirst_node(PlannedStmt, lc);
+		if ( (node = findIndexScanNodeT(stmt->planTree)) != NULL ){
+			plan = stmt;
+		}
+	}
+	enable_seqscan = old_enable_seqscan;
+	return plan;
+}
