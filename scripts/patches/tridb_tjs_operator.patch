+
+-- TRIDB(DEV-1169 / FR-4): Traversal-Join-Similarity (TJS) operator. Composes all three modalities —
+-- graph traversal + relational filter + vector similarity — in ONE plan with a single global,
+-- early-terminating top-k. The VECTOR leg (HNSW IndexScan, xs_orderbyvals[0]) is the sole rank
+-- authority; the RELATIONAL filter is pushed into its WHERE; the GRAPH leg is a reachability
+-- predicate probing graph_store.neighbors(src). attr_exp's FIRST column must be the candidate's
+-- graph id. src < 0 disables the graph leg. NOT IMMUTABLE/PARALLEL SAFE: it drives the executor
+-- via SPI and reads live graph state. See docs/decisions/0007-tjs-operator.md.
+CREATE FUNCTION tjs(table_name text, k integer, term_cond integer, src bigint,
+                    attr_exp text, filter_exp text, orderby_exp text) RETURNS SETOF record
+	AS 'MODULE_PATHNAME' LANGUAGE C STABLE;
+
+-- TR-1 / SM-3 probe: ANN candidates pulled by the last TJS scan in this backend. Asserting this
+-- << corpus proves early termination (no blocking full scan). Mirrors graph_store.visits().
+CREATE FUNCTION tjs_candidates_examined() RETURNS bigint
+	AS 'MODULE_PATHNAME' LANGUAGE C;
