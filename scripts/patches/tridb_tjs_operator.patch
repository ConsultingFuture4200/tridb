+inline uint64_t castToUint64T(const ItemPointerData& key)
+{
+	return (((uint64_t)key.ip_blkid.bi_hi)<<32) |
+		(((uint64_t)key.ip_blkid.bi_lo)<<16) | (uint64_t)key.ip_posid;
+}
+
+typedef std::pair<float, HeapTuple> pq_item_t;
+
+struct pq_item_compare_lt_t
+{
+	bool operator()(const pq_item_t& lhs, const pq_item_t& rhs)
+	{
+		return lhs.first < rhs.first;
+	}
+};
+
+inline HeapTuple copyItemT(TupleTableSlot* slot){
+	return ExecCopySlotHeapTuple(slot);
+}
+
+// ---------------------------------------------------------------------------
+// The graph reachability predicate.
+//
+// graphReachableT(src) probes graph_store.neighbors(src) — the v0 native graph store's
+// adjacency-list traversal iterator (src/graph_store_ext/graph_store.c) — via SPI and returns the
+// set of reachable destination ids. We resolve this ONCE at init (TJS Open) and cache it, rather
+// than interleaving a graph SPI probe inside the SPI-driven IndexScan loop: nesting a second SPI
+// cursor under the executor-driven scan risks SPI-stack confusion, and the reachable set is finite
+// so caching it is exact. Membership is then an O(1) hash lookup per vector candidate.
+//
+// This honors golden rule 3 (graph is native traversal, NOT a relational join): we call the graph
+// store's own iterator, not a join over an edge table.
+// ---------------------------------------------------------------------------
+static std::unordered_set<int64> graphReachableT(int64 src){
+	std::unordered_set<int64> reachable;
+	char cmd[256];
+	snprintf(cmd, sizeof(cmd),
+			 "SELECT dst FROM graph_store.neighbors(%lld) AS dst", (long long) src);
+
+	SPI_connect();
+	int ret = SPI_exec(cmd, 0);
+	if (ret != SPI_OK_SELECT)
+		elog(ERROR, "TJS graph predicate: graph_store.neighbors(%lld) probe failed (%d)",
+			 (long long) src, ret);
+
+	uint64 proc = SPI_processed;
+	TupleDesc tupdesc = SPI_tuptable->tupdesc;
+	for (uint64 i = 0; i < proc; i++) {
+		bool isnull;
+		Datum d = SPI_getbinval(SPI_tuptable->vals[i], tupdesc, 1, &isnull);
+		if (!isnull)
+			reachable.insert(DatumGetInt64(d));
+	}
+	SPI_finish();
+	return reachable;
+}
+
+// ---------------------------------------------------------------------------
+// TJSState — the generalized FaginsState. One vector orderby leg (the rank authority) plus the
+// cached graph-reachability set; the relational filter is already baked into the vector leg's SQL.
+// ---------------------------------------------------------------------------
+typedef struct{
+	PlanState ps;
+	uint32_t topk;
+	uint32_t term_cond;
+	bool finish;
+
+	std::priority_queue<pq_item_t, std::vector<pq_item_t>, pq_item_compare_lt_t> *proc_pq;
+	std::unordered_set<uint64_t> *seenSet;
+	std::stack<pq_item_t> *result_stack;
+
+	// Graph leg: the reachability predicate. graphEnabled=false means "no graph constraint"
+	// (src < 0), in which case TJS degenerates to vector+relational (and matches multicol_topk on a
+	// single orderby — increment 0's parity check).
+	bool graphEnabled;
+	std::unordered_set<int64> *reachable;
+	int idAttno; // 1-based attribute of the candidate's graph id in the result slot (the first attr).
+
+	IndexFetchTableData *result_heap_scan;
+	Relation relation;
+	std::vector<IndexScanState*> *children;
+	std::vector<QueryDesc*>* qDescs;
+
+	// Instrumentation (increment 3 / SM-3): candidates pulled from the ANN stream this scan.
+	int64 examined;
+} TJSState;
+
+// Process-global examined counter for the last TJS scan in this backend (TR-1 probe, SM-3). Mirrors
+// graph_store.c's graph_visit_counter pattern: per-backend, read via tjs_candidates_examined().
+static int64 tjs_last_examined = 0;
+
+// ---------------------------------------------------------------------------
+// execTJS — the pure operator body. `TupleTableSlot* execTJS(PlanState*)` exactly as the prompt
+// requires, so a future CustomScan node reuses it without change. On the FIRST call it drains the
+// ANN stream (early-terminating) into the bounded priority queue and unspools it into result_stack;
+// each subsequent call pops one row. This is the multicol_topk execFagins merge, generalized with
+// the graph-reachability predicate inserted at the seen-set point.
+// ---------------------------------------------------------------------------
+extern "C" TupleTableSlot* execTJS(PlanState* node){
+	TJSState* estate = (TJSState*) node;
+	uint32_t k = estate->topk;
+	uint32_t term_cond = estate->term_cond;
+	uint32_t consecutive_drops = 0;
+
+	auto proc_pq = estate->proc_pq;
+	auto seenSet = estate->seenSet;
+	auto result_stack = estate->result_stack;
+
+	TupleTableSlot* result_slot = estate->ps.ps_ResultTupleSlot;
+
+	// Drain only on the first call (result_stack empty AND not finished). On later calls we just pop
+	// the already-computed top-k. The std::stack emptiness alone is ambiguous (a genuinely empty
+	// top-k also leaves it empty), so guard on estate->finish: it is set true exactly once the merge
+	// has run to completion below.
+	if (!estate->finish) {
+		while (!estate->finish){
+			TupleTableSlot* slot;
+
+			// Single ordered stream: the vector leg. (children->size()==1; the loop keeps the
+			// execFagins shape so the structure stays recognizable / reusable.)
+			for ( unsigned int orderby_id = 0; orderby_id < estate->children->size(); orderby_id++){
+				auto child      = estate->children->at(orderby_id);
+				auto q_estate   = estate->qDescs->at(orderby_id)->estate;
+				auto oldcontext = MemoryContextSwitchTo(q_estate->es_query_cxt);
+
+				slot = ExecProcNode((PlanState*) child);
+
+				if ( TupIsNull(slot) ) {
+					estate->finish = true;
+					MemoryContextSwitchTo(oldcontext);
+					break;
+				}
+
+				estate->examined++;
+
+				// VECTOR leg: the TRUE distance is xs_orderbyvals[0] — the sole rank authority.
+				float rank_score = DatumGetFloat4(child->iss_ScanDesc->xs_orderbyvals[0]);
+
+				ItemPointerData tid = child->iss_ScanDesc->xs_heaptid_orig;
+				uint64_t tid_uint = castToUint64T(tid);
+				if ( seenSet->find(tid_uint) != seenSet->end() ) {
+					MemoryContextSwitchTo(oldcontext);
+					continue;
+				}
+				seenSet->insert(tid_uint);
+
+				// GRAPH leg: reachability predicate. The candidate's graph id is attribute idAttno
+				// of the slot (attr_exp's first column, by contract `id`). A candidate that is not
+				// reachable from src is DROPPED — counted as a consecutive_drop just like a
+				// distance loss, so it neither pollutes the result PQ nor breaks early termination.
+				bool graph_ok = true;
+				if (estate->graphEnabled) {
+					int64 cand_id;
+					if (getAttrAsInt64T(slot, estate->idAttno, &cand_id))
+						graph_ok = (estate->reachable->find(cand_id) != estate->reachable->end());
+					else
+						graph_ok = false; // NULL id is never reachable.
+				}
+
+				consecutive_drops++;
+				// RELATIONAL leg already applied in the WHERE clause; here only graph + distance can
+				// drop a survivor. Insert into the bounded top-k PQ iff reachable AND it beats the
+				// current k-th best (or the PQ is not yet full).
+				if ( graph_ok && ( proc_pq->size() < k || proc_pq->top().first > rank_score ) ){
+					if ( proc_pq->size() == k )
+						proc_pq->pop();
+					proc_pq->push(std::make_pair(rank_score, copyItemT(slot)));
+					consecutive_drops = 0;
+				}
+
+				MemoryContextSwitchTo(oldcontext);
+			}
+
+			// EARLY TERMINATION (TR-1): reuse VBASE's consecutive_drops bound verbatim — do NOT
+			// invent a new stop. Once `term_cond` consecutive candidates fail to improve the top-k,
+			// the ANN stream provably cannot beat the current k-th best, so finish (which then
+			// Close()s the child below, propagating the stop into the HNSW beam).
+			if ( consecutive_drops >= term_cond ) {
+				estate->finish = true;
+			}
+		}
+
+		// Smallest score first.
+		while (!proc_pq->empty()){
+			result_stack->push(proc_pq->top());
+			proc_pq->pop();
+		}
+		tjs_last_examined = estate->examined;
+	}
+
+	if (result_stack->size() == 0)
+		return ExecClearTuple(result_slot);
+
+	auto top = result_stack->top();
+	HeapTuple tuple = top.second;
+	result_stack->pop();
+
+	ExecForceStoreHeapTuple(tuple, result_slot, true);
+	return result_slot;
+}
+
+TJSState* InitTJSState(Relation relation, uint32_t k, uint32_t term_cond,
+					   std::vector<IndexScanState*> scans, std::vector<QueryDesc*> qDescs,
+					   bool graphEnabled, std::unordered_set<int64> reachable){
+	TJSState* state = (TJSState*)malloc(sizeof(TJSState));
+	memset(&(state->ps), 0, sizeof(PlanState));
+
+	// Single-leg: the result tuple desc is the child's verbatim (no rank column to drop, unlike the
+	// multi-orderby multicol_topk path).
+	state->ps.ps_ResultTupleDesc = scans[0]->ss.ps.ps_ResultTupleDesc;
+	state->ps.ps_ResultTupleSlot = MakeTupleTableSlot(state->ps.ps_ResultTupleDesc,
+													  scans[0]->ss.ps.ps_ResultTupleSlot->tts_ops);
+	state->ps.ExecProcNode = execTJS;
+
+	state->relation        = relation;
+	state->finish          = false;
+	state->topk            = k;
+	state->term_cond       = term_cond;
+
+	state->result_heap_scan = table_index_fetch_begin(relation);
+	state->proc_pq          = new std::priority_queue<pq_item_t, std::vector<pq_item_t>, pq_item_compare_lt_t>();
+	state->seenSet          = new std::unordered_set<uint64_t>();
+	state->result_stack     = new std::stack<pq_item_t>();
+	state->children         = new std::vector<IndexScanState*>(scans);
+	state->qDescs           = new std::vector<QueryDesc*>(qDescs);
+
+	state->graphEnabled     = graphEnabled;
+	state->reachable        = new std::unordered_set<int64>(std::move(reachable));
+	state->idAttno          = 1; // attr_exp's first column is the candidate id by contract.
+	state->examined         = 0;
+
+	return state;
+}
+
+void EndTJSState(TJSState *state){
+	if (!state) return;
+	table_index_fetch_end(state->result_heap_scan);
+	table_close(state->relation, AccessShareLock);
+	ExecDropSingleTupleTableSlot(state->ps.ps_ResultTupleSlot);
+
+	for (QueryDesc* queryDesc: *(state->qDescs)) {
+		ExecutorFinish(queryDesc);
+		ExecutorEnd(queryDesc);
+		FreeQueryDesc(queryDesc);
+	}
+	delete(state->proc_pq);
+	delete(state->seenSet);
+	delete(state->result_stack);
+	delete(state->reachable);
+	auto qDescs = state->qDescs;
+	free(state);
+	delete(qDescs);
+	return;
+}
+
+void parseVectorConstantT(std::string &src) {
+	std::size_t pos = 0;
+	while ((pos = src.find("{", pos)) != std::string::npos) {
+		src.replace(pos, 1, "\'{");
+		pos += 2;
+	}
+	pos = 0;
+	while ((pos = src.find("}", pos)) != std::string::npos) {
+		src.replace(pos, 1, "}\'");
+		++pos;
+	}
+}
+
+// ---------------------------------------------------------------------------
+// tjs(table_name, k, term_cond, src, attr_exp, filter_exp, orderby_exp) RETURNS SETOF record
+//
+//   table_name  — the relational+vector table (e.g. 'entities').
+//   k           — global top-k.
+//   term_cond   — VBASE consecutive-drops early-termination bound (0 -> default 50).
+//   src         — graph source vertex; the predicate keeps only candidates reachable
+//                 (src)-[:related_to]->(cand). src < 0 disables the graph leg (vector+relational
+//                 only — the increment-0 parity case).
+//   attr_exp    — output columns; the FIRST must be the candidate's graph id (used by the
+//                 reachability predicate). e.g. 'id'.
+//   filter_exp  — RELATIONAL leg: pushed into the vector leg's SQL WHERE (e.g. 'ts < 500'). '' = none.
+//   orderby_exp — VECTOR leg: the HNSW orderby (e.g. 'embedding <-> ''{19,0,0,0,0,0,0,0}''').
+// ---------------------------------------------------------------------------
+Datum tjs(PG_FUNCTION_ARGS) {
+
+	FuncCallContext		*funcctx;
+	int					 call_cntr;
+	int					 max_calls;
+	TupleDesc			 tupdesc;
+	AttInMetadata		*attinmeta;
+
+	if (SRF_IS_FIRSTCALL()) {
+		MemoryContext	oldcontext;
+		funcctx = SRF_FIRSTCALL_INIT();
+		oldcontext = MemoryContextSwitchTo(funcctx->multi_call_memory_ctx);
+
+		int argc = 0;
+		text *tablename = PG_GETARG_TEXT_PP(argc++);
+		uint32 k = PG_GETARG_UINT32(argc++);
+		Oid table_oid = getrelidT(std::string(text_to_cstring(tablename)));
+
+		uint32 termCond = PG_GETARG_UINT32(argc++);
+		if (termCond == 0)
+			termCond = 50;
+
+		int64 src = PG_GETARG_INT64(argc++);
+		bool graphEnabled = (src >= 0);
+
+		text* attr_exp_text   = PG_GETARG_TEXT_PP(argc++);
+		text* filter_exp_text = PG_GETARG_TEXT_PP(argc++);
+		text* orderby_text    = PG_GETARG_TEXT_PP(argc++);
+
+		DEBUG_PRINT("TJS: table=%s k=%u term=%u src=%lld attr=%s filter=%s orderby=%s",
+					text_to_cstring(tablename), k, termCond, (long long) src,
+					text_to_cstring(attr_exp_text), text_to_cstring(filter_exp_text),
+					text_to_cstring(orderby_text));
+
+		// GRAPH leg: resolve the reachable set ONCE (before driving the SPI IndexScan).
+		std::unordered_set<int64> reachable;
+		if (graphEnabled)
+			reachable = graphReachableT(src);
+
+		std::vector<IndexScanState*> scannodes;
+		std::vector<QueryDesc*> qDescs;
+		SPI_connect();
+
+		// Build the vector leg: a single index-scan SQL with the relational filter in WHERE.
+		std::string orderby(text_to_cstring(orderby_text));
+		char sourceText[102400];
+		if ( strlen(text_to_cstring(filter_exp_text)) == 0 ){
+			snprintf(sourceText, sizeof(sourceText), "select %s from %s order by %s",
+					 text_to_cstring(attr_exp_text), text_to_cstring(tablename), orderby.c_str());
+		} else {
+			snprintf(sourceText, sizeof(sourceText), "select %s from %s where %s order by %s",
+					 text_to_cstring(attr_exp_text), text_to_cstring(tablename),
+					 text_to_cstring(filter_exp_text), orderby.c_str());
+		}
+		DEBUG_PRINT("TJS vector leg SQL: %s", sourceText);
+
+		PlannedStmt* plan = NULL;
+		if ( !(plan = extractIndexScanNodeT(sourceText)) )
+			elog(ERROR, "TJS: cannot find HNSW index for vector leg = %s", sourceText);
+
+		QueryEnvironment *queryEnv = create_queryEnv();
+		DestReceiver * dest = CreateDestReceiver(DestNone);
+		QueryDesc* queryDesc = CreateQueryDesc(plan, sourceText,
+											   GetActiveSnapshot(), InvalidSnapshot,
+											   dest, NULL, queryEnv, 0);
+		qDescs.push_back(queryDesc);
+		standard_ExecutorStart(queryDesc, 0);
+
+		IndexScanState* scannode = findIndexScanStateT(queryDesc->planstate);
+		if (!scannode)
+			elog(ERROR, "TJS: no IndexScanState in vector leg plan");
+		scannodes.push_back(scannode);
+
+		TJSState* top_execNode = InitTJSState(table_open(table_oid, AccessShareLock),
+											  k, termCond, scannodes, qDescs,
+											  graphEnabled, std::move(reachable));
+
+		funcctx->user_fctx = top_execNode;
+		funcctx->max_calls = k;
+		tupdesc = top_execNode->ps.ps_ResultTupleDesc;
+		attinmeta = TupleDescGetAttInMetadata(tupdesc);
+		funcctx->attinmeta = attinmeta;
+
+		MemoryContextSwitchTo(oldcontext);
+	}
+
+	funcctx = SRF_PERCALL_SETUP();
+	call_cntr = funcctx->call_cntr;
+	max_calls = funcctx->max_calls;
+	attinmeta = funcctx->attinmeta;
+
+	TJSState* top_execNode = (TJSState*)funcctx->user_fctx;
+
+	if (call_cntr < max_calls) {
+		TupleTableSlot *slot = execTJS((PlanState*) top_execNode);
+		if ( TupIsNull(slot) )
+			goto finish;
+		Datum result = ExecFetchSlotHeapTupleDatum(slot);
+		SRF_RETURN_NEXT(funcctx, result);
+	}
+	else {
+		goto finish;
+	}
+
+ finish:
+	EndTJSState(top_execNode);
+	SPI_finish();
+	DEBUG_PRINT("TJS done, processed = %u", call_cntr);
+	SRF_RETURN_DONE(funcctx);
+}
+
+// ---------------------------------------------------------------------------
+// tjs_candidates_examined() — TR-1 / SM-3 probe: ANN candidates pulled by the last TJS scan in this
+// backend. Asserting this << corpus proves early termination (no blocking full scan). Mirrors
+// graph_store.visits().
+// ---------------------------------------------------------------------------
+extern "C"
+{
+    PGDLLEXPORT PG_FUNCTION_INFO_V1(tjs_candidates_examined);
+}
+
+Datum tjs_candidates_examined(PG_FUNCTION_ARGS) {
+	PG_RETURN_INT64(tjs_last_examined);
+}
