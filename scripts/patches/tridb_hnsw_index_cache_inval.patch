 std::map<std::string, std::shared_ptr<hnswlib::HierarchicalNSW<float>>> HNSWIndexScan::vector_index_map;
+// TRIDB ADR-0014 (advisor plan 052): see hnswindex_scan.hpp for the rationale.
+std::map<Oid, std::string> HNSWIndexScan::relid_to_path_map;
+
+// TRIDB ADR-0014 (advisor plan 052): relcache-invalidation callback (CacheRegisterRelcacheCallback
+// signature: void(Datum, Oid)). Fires on DROP INDEX / REINDEX / any relation rewrite that
+// invalidates a relcache entry — including, with relid == InvalidOid, a "flush everything"
+// notification. A pooled backend that never re-derives its cache key otherwise keeps serving the
+// STALE (or, on a dimension change, wrong-dimension/OOB) graph forever (the bug this ADR fixes).
+//
+// Ownership rule (mandatory, ADR-0014): this callback ONLY erases map entries. It never frees,
+// mutates, or saves the underlying HierarchicalNSW directly — dropping vector_index_map's
+// shared_ptr reference merely lets the refcount fall; the object itself is freed only once every
+// last holder (including a WorkSpace/TridbVectorIter::indexKeepalive copy taken by an in-flight
+// BeginScan) releases it. The very next LoadIndex on this path then cache-misses and the existing
+// DEV-1235 rebuild-on-recovery path repopulates from the live heap — no rebuild logic changes.
+//
+// Concurrency: Postgres backends are single-threaded, and invalidation callbacks fire
+// synchronously on the same backend thread that would otherwise be inside a scan (e.g. at
+// AcceptInvalidationMessages during CommandCounterIncrement/lock acquisition, never re-entrant
+// with an in-progress hnsw_gettuple pull) — so no lock around these maps is required beyond that
+// single-threaded-per-backend assumption, which the ADR requires be stated explicitly here.
+static void
+HNSWCacheInvalCallback(Datum /*arg*/, Oid relid)
+{
+    if (relid == InvalidOid)
+    {
+        // "Flush everything" notification: erase every entry rather than try to figure out which
+        // ones are stale. Correct-but-conservative — the next access to any index simply rebuilds.
+        HNSWIndexScan::vector_index_map.clear();
+        HNSWIndexScan::distanceFunction_map.clear();
+        HNSWIndexScan::relid_to_path_map.clear();
+        return;
+    }
+
+    auto found = HNSWIndexScan::relid_to_path_map.find(relid);
+    if (found == HNSWIndexScan::relid_to_path_map.end())
+        return;   // not an index this backend has ever loaded — nothing cached to erase.
+
+    const std::string path = found->second;
+    HNSWIndexScan::vector_index_map.erase(path);
+    HNSWIndexScan::distanceFunction_map.erase(path);
+    HNSWIndexScan::relid_to_path_map.erase(found);
+}
+
+void HNSWIndexScan::RegisterInvalidationCallback()
+{
+    CacheRegisterRelcacheCallback(HNSWCacheInvalCallback, (Datum) 0);
+}
 
