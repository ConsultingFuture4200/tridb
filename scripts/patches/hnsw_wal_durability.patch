+// Copyright (c) TriDB. Licensed under the MIT License.
+//
+// TRIDB: HNSW WAL durability (DEV-1235) — DRAFT / UNBUILT / GX10-gated (ADR-0009).
+//
+// GenericXLog-backed page mutations for the HNSW index. Mirrors the WAL pattern
+// in src/graph_store/graph_am.c: every page change is registered with
+// GenericXLogRegisterBuffer and committed with GenericXLogFinish inside the
+// caller's transaction, so it redoes from the host WAL after a crash and rolls
+// back with the transaction. NO second WAL. NO flat-file source of truth.
+//
+// The bodies below are TODO(GX10) STUBS. They establish the structure and the
+// invariants but must be implemented and BUILT on the GX10 before any durability
+// claim. They intentionally elog(ERROR) if reached unbuilt so a half-applied
+// DRAFT fails LOUD rather than silently losing data.
+#include "tridb_hnsw_wal.hpp"
+
+extern "C"
+{
+#include <access/generic_xlog.h>
+#include <storage/bufmgr.h>
+#include <utils/elog.h>
+}
+
+namespace tridb {
+
+// Reference (graph_am.c): GenericXLogStart(rel) -> ... RegisterBuffer ... ->
+// GenericXLogFinish(state). We acquire the WAL state for the index relation here
+// and finish it in the destructor so one HnswWalScope == one atomic page batch.
+HnswWalScope::HnswWalScope(Relation idx) : index(idx), xlog_state(nullptr)
+{
+    // TODO(GX10): xlog_state = (void *) GenericXLogStart(index);
+    // Until implemented, this seam is inert; the caller must NOT claim durability.
+}
+
+HnswWalScope::~HnswWalScope()
+{
+    // TODO(GX10): if (xlog_state) GenericXLogFinish((GenericXLogState *) xlog_state);
+    // On exception/abort the txn machinery discards the registered buffers; never
+    // an ad-hoc flat-file write here.
+}
+
+void hnsw_wal_log_insert(HnswWalScope & /*scope*/,
+                         std::uint64_t /*label*/,
+                         const float * /*vec*/,
+                         int /*dim*/)
+{
+    // TODO(GX10): lay the new point's level-0 record + link list + header deltas
+    // into the index relation's pages, registering each touched buffer with
+    // GenericXLogRegisterBuffer (GENERIC_XLOG_FULL_IMAGE for a freshly extended
+    // page, 0 for an in-place delta) — exactly as gph_insert_edge does for the
+    // adjacency pages. This is the line that closes the FR-7 redo gap.
+    ereport(ERROR,
+            (errcode(ERRCODE_FEATURE_NOT_SUPPORTED),
+             errmsg("TRIDB DEV-1235: HNSW WAL-durability seam is a DRAFT STUB "
+                    "(unbuilt) — must be implemented + built on the GX10 before "
+                    "incremental HNSW inserts can be claimed crash/abort-durable")));
+}
+
+void hnsw_wal_log_delete(HnswWalScope & /*scope*/, std::uint64_t /*label*/)
+{
+    // TODO(GX10): WAL-log the deleted-flag page change (markDelete tombstone).
+    ereport(ERROR,
+            (errcode(ERRCODE_FEATURE_NOT_SUPPORTED),
+             errmsg("TRIDB DEV-1235: HNSW WAL-durability delete seam is a DRAFT "
+                    "STUB (unbuilt)")));
+}
+
+void hnsw_wal_rehydrate(Relation /*index*/, void * /*hnsw_index_out*/)
+{
+    // TODO(GX10): rebuild the in-RAM HierarchicalNSW from the WAL-RECOVERED
+    // relation forks, NOT the flat file. After redo, the relation pages are the
+    // source of truth; the flat file (if kept) is only a validated warm cache.
+    ereport(ERROR,
+            (errcode(ERRCODE_FEATURE_NOT_SUPPORTED),
+             errmsg("TRIDB DEV-1235: HNSW WAL-durability rehydrate seam is a "
+                    "DRAFT STUB (unbuilt)")));
+}
+
+}  // namespace tridb
