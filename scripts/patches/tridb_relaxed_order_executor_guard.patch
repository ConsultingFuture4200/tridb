diff --git a/thirdparty/Postgres/src/backend/access/index/genam.c b/thirdparty/Postgres/src/backend/access/index/genam.c
--- a/thirdparty/Postgres/src/backend/access/index/genam.c
+++ b/thirdparty/Postgres/src/backend/access/index/genam.c
@@ -125,6 +125,12 @@
 	scan->xs_hitup = NULL;
 	scan->xs_hitupdesc = NULL;
 
+	/* TRIDB: relaxed-order guard (advisor plan 022) — zero-init the VBASE
+	 * relaxed-monotonicity flag so stock (non-relaxed) AMs never read garbage.
+	 * Only the HNSW AM sets it true; nodeSort's bounded early-stop is gated on
+	 * it AND amcanrelaxedorderbyop. See docs/decisions/0007-tjs-operator.md. */
+	scan->xs_inorder = false;
+
 	return scan;
 }
 
