+// TRIDB DEV-1354 — TR-1 HARD WORK-BOUND for the plain relaxed-order HNSW scan (hnsw_gettuple).
+// The VBASE iterative iterator ignores ef_ and can expand the whole graph, so a plain
+// `ORDER BY embedding <-> q LIMIT k` scan whose xs_inorder emission-window flip never trips
+// drains ~all N nodes (the deterministic 1M hang). This GUC caps the candidates such a scan may
+// examine, guaranteeing bounded termination at any corpus size; the executor still returns the
+// true top-k by distance among those examined. 0 disables the ceiling (legacy unbounded scan).
+// Read via `extern int hnsw_max_examined_guc;` in hnswindex.cpp (the hnsw_gettuple hot loop).
+int hnsw_max_examined_guc = 1000;
+
 #ifdef WITH_SPTAG
 relopt_enum_elt_def sptag_DistCalcMethodValues[] =
 {
@@ -83,4 +94,24 @@
                         "Valid values are \"inner_product\" and \"l2_distance\".",
                         AccessExclusiveLock);
 
+    // TRIDB DEV-1354 — register the plain relaxed-order HNSW scan TR-1 work-bound. PGC_USERSET so a
+    // plain `SET vectordb.hnsw_max_examined = N` tunes the recall/latency knob per session with no
+    // rebuild. Default 1000; 0 disables (legacy unbounded scan). This is the plain-scan analog of
+    // vectordb.tjs_open_max_examined (registered lazily in tjs_open_operator.cpp).
+    DefineCustomIntVariable(
+        "vectordb.hnsw_max_examined",
+        "Absolute ceiling on candidates a plain relaxed-order HNSW ORDER BY scan may examine (TR-1 work bound).",
+        "The VBASE relaxed-monotonicity iterator ignores ef_ and can expand the whole graph; at large N "
+        "the xs_inorder emission-window flip never trips, so a plain ORDER BY <-> LIMIT k scan drains the "
+        "entire corpus (unbounded work, a TR-1 violation). This caps examined candidates so the scan always "
+        "terminates; the executor still returns the true top-k by distance among those examined. 0 disables "
+        "the ceiling. Does not affect the range-filter (WHERE <-> < t) branch, which has its own bound.",
+        &hnsw_max_examined_guc,
+        1000,       /* boot / default */
+        0,          /* min: 0 = unbounded */
+        INT_MAX,    /* max */
+        PGC_USERSET,
+        0,
+        NULL, NULL, NULL);
+
 }
