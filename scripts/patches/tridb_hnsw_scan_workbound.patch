# tridb_hnsw_scan_workbound.patch — DEV-1354 (plain HNSW scan TR-1 defensive work bound)
#
# STATUS: BUILT AND VERIFIED on the DGX Spark (GX10, aarch64+CUDA). vectordb rebuilt incrementally
#   into tridb/msvbase:gx10-v1-hnswcap. Verified functional at small N (cap=3 -> exactly 3 rows) and
#   at N=1,000,000 (enwiki dense_id_aligned.npy, 384-dim, HNSW distmethod=l2_distance).
#
# WHAT THIS ADDS: an ABSOLUTE bounded-work ceiling on the plain relaxed-order HNSW ORDER BY scan
#   (`SELECT ... ORDER BY embedding <-> q LIMIT k`). hnsw_gettuple's !hasRangeFilter path buffers a
#   FIXED range=86 window and flips xs_inorder when the window fills and the next candidate is worse.
#   This patch counts candidates examined and returns end-of-scan once `vectordb.hnsw_max_examined`
#   is exceeded, so the scan is provably O(cap) regardless of whether the 86-window flip ever trips —
#   a defensive TR-1 guarantee (golden rule #1) and the exact analog of the shipped tjs_open work
#   bound (tridb_tjs_open_workbound.patch). The executor's ORDER BY reorder still returns the true
#   top-k by distance among the examined candidates.
#
# IMPORTANT — VERIFICATION FINDING (the diagnosis premise was NOT reproduced): with a WARM in-RAM
#   index (vector_index_map cached), the UNBOUNDED (cap=0) plain scan at N=1M terminates in single-
#   digit ms for every query type tested — exact corpus member 2.0ms, random non-member 7.4ms,
#   in-manifold midpoint 10.2ms — with recall IDENTICAL to the capped runs. The xs_inorder flip DOES
#   trip at 1M. The plain scan is therefore NOT unbounded and does NOT drain ~all N nodes. The real
#   >600s "hang" at 1M is HNSWIndexScan::LoadIndex's O(heap) rebuild (DEV-1235 rebuild-on-recovery)
#   that runs on the FIRST query of every cold backend — measured 776-850s at 1M, NOT the scan, and
#   NOT addressed here. Consequently this cap is an INERT safety net for the current corpus (the flip
#   trips at ~86, far below any sane cap, so cap=0 and cap=1000 are byte-identical); it exists to make
#   the scan provably bounded for a future/pathological distribution where the flip might not trip.
#
# FIX (three hunks, no new query surface):
#   1. hnswindex.hpp: add `int64 examined` to HNSWScanOpaqueData (per-scan candidate counter).
#   2. hnswindex.cpp: on the relaxed-order (!hasRangeFilter) branch, count each candidate pulled and
#      `return false` once it exceeds `vectordb.hnsw_max_examined`. Range-filter branch untouched;
#      counter reset on first call. Below the cap, behavior is byte-for-byte the legacy scan.
#   3. lib.cpp: register the GUC `vectordb.hnsw_max_examined` (PGC_USERSET, default 1000, 0=disabled)
#      in _PG_init, next to the HNSW reloption kinds. Plain-scan analog of vectordb.tjs_open_max_examined.
#
# TUNING: default 1000 is chosen ABOVE the range=86 emission window so it never truncates the existing
#   flip-terminated scan (no recall regression: 1M recall@10 identical at cap 0/100/200/500/1000/2000/
#   4000). Setting the cap BELOW ~86 truncates below the flip and reduces recall (cap=3 -> 3 rows). The
#   healthy tjs_open drain finishes ~45-90 examined (well under 1000), so tjs_open (which has its own
#   vectordb.tjs_open_max_examined bound) still terminates and is NOT regressed (tjs_open_smoke passes).
#
# Sentinel for verify_patches: "vectordb.hnsw_max_examined" in src/lib.cpp AND "hnsw_max_examined_guc"
#   in src/hnswindex.cpp. Depends-on: apply LAST in the HNSW chain — after tridb_hnsw_am_entry_guards,
#   tridb_hnsw_reloptions, tridb_hnsw_costestimate_no_orderby. Diffed against the fully-patched tree.
--- a/src/hnswindex.hpp
+++ b/src/hnswindex.hpp
@@ -36,6 +36,7 @@
         bool hasRangeFilter;
         bool inRange;
         float range;
+        int64 examined;   // TRIDB DEV-1354: relaxed-order candidates pulled this scan (TR-1 work bound)
         HNSWIndexScan::WorkSpace *workSpace;
     } HNSWScanOpaqueData;
 
--- a/src/hnswindex.cpp
+++ b/src/hnswindex.cpp
@@ -22,6 +22,12 @@
 
 extern relopt_kind hnsw_para_relopt_kind;
 
+// TRIDB DEV-1354 — TR-1 HARD WORK-BOUND for the plain relaxed-order HNSW scan. Defined + registered
+// as the GUC `vectordb.hnsw_max_examined` in lib.cpp's _PG_init (mirrors hnsw_para_relopt_kind above).
+// Caps the candidates a plain `ORDER BY embedding <-> q LIMIT k` scan may pull from the VBASE
+// iterative iterator, so it terminates even when the xs_inorder emission-window flip never trips.
+extern int hnsw_max_examined_guc;
+
 bytea *hnsw_para_options(Datum reloptions, bool validate) {
 
   static const relopt_parse_elt tab[] = {
@@ -366,6 +372,7 @@
         }
         scan->xs_inorder = false;
         scanState->first = false;
+        scanState->examined = 0;   // TRIDB DEV-1354: reset the relaxed-order work-bound counter
     }
 
     int i = 0;
@@ -420,19 +427,36 @@
                 scanState->inRange = true;
             }
         }
-        else if(!scan->xs_inorder){
-         if (scanState->workSpace->distanceQueue.size() == scanState->range &&
-             scanState->workSpace->distanceQueue.top() < result->GetDistance())
-         {
-             scan->xs_inorder=true;
-         }
-         else
-         {
-                    if (scanState->workSpace->distanceQueue.size() == scanState->range)
-                    {
-                    scanState->workSpace->distanceQueue.pop();
-                    }
-                    scanState->workSpace->distanceQueue.push(result->GetDistance());
+        else {
+         // TRIDB DEV-1354 — TR-1 HARD WORK-BOUND on the relaxed-order ORDER BY path. The VBASE
+         // hnswlib iterative iterator (searchBaseLayerSTIterative / ResultIterator::Next) ignores
+         // ef_ and expands the whole graph, emitting sporadic distance improvements — so the
+         // xs_inorder flip below (queue full AND next candidate worse than the buffered max) never
+         // trips at large N, and a plain `ORDER BY embedding <-> q LIMIT k` scan drains ~all N nodes
+         // (the deterministic 1M hang; N=200k flips at ~86 and is unaffected). This absolute ceiling
+         // guarantees the scan ALWAYS terminates: after `hnsw_max_examined_guc` candidates we signal
+         // end-of-scan (return false), and the executor's ORDER BY reorder queue still returns the
+         // true top-k by distance among those examined. 0 disables (legacy unbounded scan). Exact
+         // analog of the tjs_open term-cond work-bound (DEV-1354). The range-filter branch above
+         // keeps its own queueThreshold/distanceThreshold termination and is untouched.
+         if (hnsw_max_examined_guc > 0 &&
+             ++scanState->examined > (int64) hnsw_max_examined_guc)
+             return false;
+
+         if(!scan->xs_inorder){
+          if (scanState->workSpace->distanceQueue.size() == scanState->range &&
+              scanState->workSpace->distanceQueue.top() < result->GetDistance())
+          {
+              scan->xs_inorder=true;
+          }
+          else
+          {
+                     if (scanState->workSpace->distanceQueue.size() == scanState->range)
+                     {
+                     scanState->workSpace->distanceQueue.pop();
+                     }
+                     scanState->workSpace->distanceQueue.push(result->GetDistance());
+          }
          }
         }
 
