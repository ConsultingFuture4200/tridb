# tridb_fix_double_scan_snapshot.patch — DRAFT, UNBUILT (DEV-1236)
#
# STATUS: UNBUILT-HERE. Authored on the x86 standin in a static-verify run with NO docker image
# available. It has NOT been compiled, applied, or run. Do NOT add it to scripts/lib/msvbase_patches.sh
# or claim it builds/passes/fixes until it is verified on a built tridb/msvbase:dev image (x86 standin)
# or on the GX10 (scripts/gx10build.sh). See docs/fork_segfault_double_scan.md (§Verify wiring) and
# docs/decisions/0010-fork-operator-snapshot-lifecycle.md.
#
# CAVEAT (Linus review): this is a SKETCH, not a git-apply-clean patch. Part A (adding a
# query_snapshot field to FaginsState in multicol_topk.cpp + topk.cpp and to TJSState in
# tjs_operator.cpp) is described as PROSE, not as a unified-diff hunk — it must be authored as a
# real hunk before `git apply`. Part C's per-drive Push/Pop must additionally be wrapped in
# PG_TRY/PG_FINALLY (PopActiveSnapshot on the error path, then PG_RE_THROW) — as functions.c does —
# before this ships as the final patch. Do NOT git apply as-is.
#
# WHAT IT FIXES (DEV-1236 diagnosis): co-issuing a second executor-driven scan in the SAME plpgsql
# block as topk()/multicol_topk()/tjs() SIGSEGVs the backend. Root cause: each operator builds a
# child IndexScan via SPI and drives it across MULTIPLE SRF per-call invocations using the caller's
# active snapshot captured ONCE at CreateQueryDesc (GetActiveSnapshot()), never pinned via
# RegisterSnapshot and never re-pushed. A sibling statement in the same block refreshes/pops the
# active-snapshot stack, leaving the operator's child scan reading a popped/freed snapshot during
# ExecProcNode -> SIGSEGV. (Secondary, confirmed: a use-after-free in topk/multicol_topk teardown.)
#
# THE FIX (three parts; see the per-file hunks below):
#   1. Own the snapshot for the whole SRF lifetime: RegisterSnapshot(GetTransactionSnapshot())
#      at first-call, UnregisterSnapshot at teardown (after ExecutorEnd).
#   2. Push/pop the active snapshot around each child drive in execFagins/execFaginsM/execTJS,
#      mirroring core's postquel_* path (functions.c PushActiveSnapshot before each getnext).
#   3. Fix the teardown use-after-free + mismatched free/delete in topk.cpp & multicol_topk.cpp
#      (free(state) must be LAST; new'd members must be delete'd). tjs_operator.cpp's EndTJSState is
#      already correct on this point and only needs the snapshot changes.
#
# NOTE ON FORM: this is a hand-authored unified-diff SKETCH against the vendored sources
# (vendor/MSVBASE/src/*). Line numbers/context will need regeneration with `git apply` against the
# actual pinned MSVBASE clone before wiring (the in-tree vendor mirror and the clone can drift).
# Regenerate per the existing convention (cf. tridb_tjs_operator.patch) once verified.
#
# =====================================================================================
# Part A — store the pinned snapshot on the operator state so teardown can unregister it.
#          (Add a `Snapshot query_snapshot;` field to FaginsState / TJSState.)
# =====================================================================================
#
# --- topk.cpp / multicol_topk.cpp: in the FaginsState struct, add:
#         Snapshot query_snapshot;   // pinned (RegisterSnapshot) for the SRF's whole lifetime
# --- tjs_operator.cpp: in TJSState, add the same field (and pass it through InitTJSState).
#
# =====================================================================================
# Part B — first-call: pin a snapshot the operator owns, instead of borrowing the caller's.
# =====================================================================================
diff --git a/src/multicol_topk.cpp b/src/multicol_topk.cpp
--- a/src/multicol_topk.cpp
+++ b/src/multicol_topk.cpp
@@ -629,11 +629,18 @@ Datum multicol_topk(PG_FUNCTION_ARGS) {
 			QueryEnvironment *queryEnv = create_queryEnv(); /* query environment setup for SPI level */
 			DestReceiver * dest= CreateDestReceiver(DestNone);
 			// DEBUG_PRINT("Create QueryDesc");
-			QueryDesc* queryDesc = CreateQueryDesc(plan, sourceText,
-												   GetActiveSnapshot(), InvalidSnapshot,
-												   dest, NULL, queryEnv, 0);
+			// DEV-1236: own a snapshot for the SRF's ENTIRE multi-call lifetime. Borrowing the
+			// caller's GetActiveSnapshot() here let a sibling scan in the same plpgsql block pop/free
+			// it out from under our still-open child IndexScan -> SIGSEGV on a later ExecProcNode.
+			// RegisterSnapshot pins it against the current resource owner; UnregisterSnapshot in
+			// EndFaginsStateM (after ExecutorEnd) releases it.
+			Snapshot query_snapshot = RegisterSnapshot(GetTransactionSnapshot());
+			QueryDesc* queryDesc = CreateQueryDesc(plan, sourceText,
+												   query_snapshot, InvalidSnapshot,
+												   dest, NULL, queryEnv, 0);

 			qDescs.push_back(queryDesc);
 			// DEBUG_PRINT("Executor Start");
 			standard_ExecutorStart(queryDesc, 0);
+			// stash query_snapshot on the FaginsState below (InitFaginsState) so teardown can unregister it.

# (Identical change in topk.cpp around its CreateQueryDesc at lines 663-665, and in
#  tjs_operator.cpp around lines 617-619 — replace GetActiveSnapshot() with a RegisterSnapshot'd
#  GetTransactionSnapshot() and remember it on the state.)
#
# =====================================================================================
# Part C — each drive: push the operator's snapshot active, pop it after. (execFaginsM shown;
#          execFagins in topk.cpp and execTJS in tjs_operator.cpp get the same wrap.)
# =====================================================================================
diff --git a/src/multicol_topk.cpp b/src/multicol_topk.cpp
--- a/src/multicol_topk.cpp
+++ b/src/multicol_topk.cpp
@@ -425,6 +425,11 @@ TupleTableSlot* execFaginsM(PlanState* node){
 	// slot
 	TupleTableSlot* result_slot = estate->ps.ps_ResultTupleSlot;

+	// DEV-1236: make THIS operator's pinned snapshot the active one for the whole drive, so any
+	// active-snapshot consultation inside the child IndexScan sees our snapshot and not whatever a
+	// prior sibling statement left on the stack. Paired Pop is at every return below.
+	PushActiveSnapshot(estate->query_snapshot);
+
 	while (!estate->finish){
 		TupleTableSlot* slot;

@@ -483,6 +488,7 @@ TupleTableSlot* execFaginsM(PlanState* node){
 	while (!proc_pq->empty()){
 		result_stack->push(proc_pq->top());
 		proc_pq->pop();
 	}

-	if (result_stack->size() == 0)
+	if (result_stack->size() == 0) {
+		PopActiveSnapshot();
 		return ExecClearTuple(result_slot);
+	}

 	auto [rk_score, tuple] = result_stack->top();
 	result_stack->pop();

 	ExecForceStoreHeapTuple(tuple, result_slot, true);
+	PopActiveSnapshot();
 	return result_slot;
 }
#
# (BETTER FORM, recommended for the final patch: wrap only the child-drive loop in Push/Pop, or use
#  a PG_TRY/PG_FINALLY so the snapshot is popped on the error path too. The sketch above pops on both
#  normal returns; a PG_TRY guard is the production-correct shape.)
#
# =====================================================================================
# Part D — teardown: unregister the pinned snapshot, and FIX the use-after-free (topk/multicol_topk).
# =====================================================================================
diff --git a/src/multicol_topk.cpp b/src/multicol_topk.cpp
--- a/src/multicol_topk.cpp
+++ b/src/multicol_topk.cpp
@@ -524,16 +524,22 @@ void EndFaginsStateM(FaginsState *state){
 	if (!state) return;

 	table_index_fetch_end(state->result_heap_scan);
 	table_close(state->relation, AccessShareLock);
 	ExecDropSingleTupleTableSlot(state->ps.ps_ResultTupleSlot);

 	for (QueryDesc* queryDesc: *(state->qDescs)) {
 		ExecutorFinish(queryDesc);
 		ExecutorEnd(queryDesc);
 		FreeQueryDesc(queryDesc);
 	}
+	// DEV-1236: release the snapshot we pinned in multicol_topk() (after ExecutorEnd, which is the
+	// last reader of it).
+	if (state->query_snapshot)
+		UnregisterSnapshot(state->query_snapshot);
+
+	// DEV-1236: FIX use-after-free + mismatched free/delete. The OLD code did `free(state);` then
+	// `free(state->qDescs);` — a read of state-> AFTER free(state) — and free()'d a new[]'d vector.
+	// delete every new'd member, THEN free(state) LAST. (Mirror of the already-correct EndTJSState.)
 	delete(state->proc_pq);
 	delete(state->seenSet);
 	delete(state->result_stack);
-	free(state);
-	free(state->qDescs);
+	delete(state->qDescs);
+	delete(state->children);   // was leaked
+	free(state);               // LAST — no state-> access after this point.
 	return;
 }
#
# (topk.cpp's EndFaginsState has the IDENTICAL UAF at its lines 547-552 — apply the same reorder,
#  plus delete(state->children) which topk also leaks, plus the UnregisterSnapshot. tjs_operator.cpp's
#  EndTJSState already frees correctly; it only needs the UnregisterSnapshot line and the matching
#  field/Push/Pop from Parts A-C.)
