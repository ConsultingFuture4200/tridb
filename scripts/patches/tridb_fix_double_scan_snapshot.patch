 	Relation relation;
 	std::vector<IndexScanState*> *children;
 	std::vector<QueryDesc*>* qDescs;
+	// DEV-1236: snapshot owned by this SRF for its entire multi-call lifetime.
+	// Registered at first-call (RegisterSnapshot), unregistered in EndFaginsState
+	// (after ExecutorEnd). Never borrowed from the caller's active-snapshot stack.
+	Snapshot query_snapshot;
 } FaginsState;


@@ -424,6 +428,14 @@
 	// slot
 	TupleTableSlot* result_slot = estate->ps.ps_ResultTupleSlot;

+	// DEV-1236 Part C: push our pinned snapshot as the active one for the entire child drive so any
+	// active-snapshot consultation inside ExecProcNode sees our snapshot, not whatever a prior sibling
+	// statement in the same plpgsql block left on the active-snapshot stack.
+	// PG_TRY/PG_FINALLY mirrors core functions.c postquel_getnext: Pop on both the normal and error
+	// paths so no snapshot leak occurs if the child throws.
+	PushActiveSnapshot(estate->query_snapshot);
+	PG_TRY();
+	{
 	while (!estate->finish){
 		TupleTableSlot* slot;

