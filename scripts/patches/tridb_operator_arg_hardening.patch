+// TRIDB: operator arg hardening (advisor plan 024) — error-path memory release.
+//
+// The TJSState struct is malloc'd and its containers new'd: an ereport(ERROR) after state init
+// longjmps past EndTJSState, leaking them PERMANENTLY (palloc memory is reclaimed by the aborting
+// transaction; malloc/new memory is not). Fix: a MemoryContextCallback registered on the SRF's
+// multi-call context releases the malloc/new memory if not already released. The callback must
+// NOT touch executor/SPI/relation teardown — abort cleanup owns those via resource owners; it
+// only deletes the C++ containers and free()s the struct.
+//
+// free(state) happens ONLY in the callback (never in EndTJSState): the registered
+// MemoryContextCallback node is EMBEDDED in the struct, so freeing the struct before the context
+// resets would leave a dangling node on the context's reset-callback list (use-after-free when
+// MemoryContextDelete walks it at query end). The callback fires exactly once per context
+// reset/delete — normal completion and abort alike — so the struct is always reclaimed.
+// Future operators must copy this arg-guard + release-callback pattern.
+// ---------------------------------------------------------------------------
+static void releaseTJSStateMemory(TJSState* state){
+	if (!state || state->released)
+		return;
+	state->released = true;
+	// Containers only. HeapTuples inside them live in the SRF's multi-call context and are
+	// reclaimed by the context machinery itself — never pfree'd here.
+	delete(state->proc_pq);
+	delete(state->seenSet);
+	delete(state->result_stack);
+	delete(state->reachable);
+	delete(state->qDescs);
+	delete(state->children);
+}
+
+static void tjsStateResetCB(void* arg){
+	TJSState* state = (TJSState*) arg;
+	releaseTJSStateMemory(state);   // no-op if EndTJSState already released the containers
+	free(state);
+}
+
+// Register the release callback; call ONLY once the state's container members are all set.
+static void registerTJSStateRelease(TJSState* state, MemoryContext cxt){
+	state->released = false;
+	state->cb.func = tjsStateResetCB;
+	state->cb.arg  = state;
+	MemoryContextRegisterResetCallback(cxt, &state->cb);
+}
