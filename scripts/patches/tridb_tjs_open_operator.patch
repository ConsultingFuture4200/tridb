+
+-- TRIDB(ADR-0012 / tjs_open): seedless multi-seed open-domain retrieval operator. Additive — tjs()
+-- is unchanged. Derives m_seeds ANN seeds from the vector leg (no caller src), expands the graph
+-- from ALL seeds (hops deep) via graph_store.neighbors, and emits the top-k vector-ranked with the
+-- graph-reachable bridges injected past the vector frontier WITHOUT resetting the consecutive_drops
+-- termination bound (TR-1 preserved). attr_exp's FIRST column must be the candidate's graph id.
+CREATE FUNCTION tjs_open(table_name text, k integer, term_cond integer, m_seeds integer,
+                         hops integer, attr_exp text, filter_exp text, orderby_exp text)
+                RETURNS SETOF record
+	AS 'MODULE_PATHNAME' LANGUAGE C STABLE STRICT;
+
+COMMENT ON FUNCTION tjs_open(text, integer, integer, integer, integer, text, text, text) IS
+	'TriDB tjs_open — seedless multi-seed open-domain retrieval (ADR-0012 realization B). ANN '
+	'top-m_seeds from the vector leg -> hops-reachable graph union (bridges) -> vector-ranked top-k '
+	'with bridge injection past the frontier (drop counter not reset, so VBASE early termination '
+	'still holds). Additive to tjs(); attr/filter/orderby are raw SQL fragments — trusted input only.';
+
+-- TR-1 / SM-3 probe: ANN candidates pulled by the last tjs_open scan. << corpus proves early term.
+CREATE FUNCTION tjs_open_candidates_examined() RETURNS bigint
+	AS 'MODULE_PATHNAME' LANGUAGE C;
+
+-- Bridges admitted past the vector frontier in the last tjs_open scan (the graph contribution).
+CREATE FUNCTION tjs_open_bridges_injected() RETURNS bigint
+	AS 'MODULE_PATHNAME' LANGUAGE C;
