@@ -233,6 +288,15 @@
             else if (dim > 4)
                 fstdistfunc_ = L2SqrSIMD4ExtResiduals;
     #endif
+    #if defined(__ARM_NEON)
+            // TRIDB (DEV-1234): the USE_SSE/AVX block above is dead on aarch64 (ISA flags stripped),
+            // so fstdistfunc_ would remain the scalar L2Sqr. Select the NEON kernel instead. dim<=16
+            // non-multiples keep scalar L2Sqr (no full 16-float block to vectorize).
+            if (dim % 16 == 0)
