     src/lib.cpp
-    src/index.cpp
-    src/index_builder.cpp
-    src/index_scan.cpp
     src/hnswindex.cpp
     src/hnswindex_builder.cpp
     src/hnswindex_scan.cpp
@@ -87,9 +111,18 @@ add_library(${PROJECT_NAME} SHARED
     src/model_mng.cpp
     src/topk.cpp
     src/multicol_topk.cpp
-    src/spannindex.cpp
-    src/spannindex_scan.cpp
 )
+if(WITH_SPTAG)
+    list(APPEND VECTORDB_SOURCES
+        src/index.cpp
+        src/index_builder.cpp
+        src/index_scan.cpp
+        src/spannindex.cpp
+        src/spannindex_scan.cpp
+    )
+endif()
+
+add_library(${PROJECT_NAME} SHARED ${VECTORDB_SOURCES})
 
 target_compile_features(${PROJECT_NAME} PUBLIC cxx_std_14)
 target_compile_options(${PROJECT_NAME} PRIVATE -Wall -mavx2)
@@ -158,15 +191,12 @@ execute_process(
 install(
     FILES ${CMAKE_CURRENT_BINARY_DIR}/${EXT_CONTROL_FILE}
     DESTINATION "${PostgreSQL_SHAREDIR}/extension")
-foreach(EXT_SQL_FILE ${EXT_SQL_FILES})
-    install(
-        FILES ${CMAKE_CURRENT_SOURCE_DIR}/${EXT_SQL_FILE}
-        DESTINATION "${PostgreSQL_SHAREDIR}/extension")
-endforeach(EXT_SQL_FILE)
+# TRIDB(DEV-1228): install ONLY the assembled SQL (already named ${PROJECT_NAME}--${PROJECT_VERSION}.sql,
+# = base + optional SPTAG fragment). The old per-file foreach loop dropped an unversioned, incomplete
+# sql/vectordb.sql that PostgreSQL's loader never reads (it uses extname--version.sql); removed.
 install(
-    FILES ${CMAKE_CURRENT_SOURCE_DIR}/${EXT_SQL_MAIN}
-    DESTINATION "${PostgreSQL_SHAREDIR}/extension"
-    RENAME ${PROJECT_NAME}--${PROJECT_VERSION}.sql)
+    FILES ${EXT_SQL_INSTALLED}
+    DESTINATION "${PostgreSQL_SHAREDIR}/extension")
 install(
     TARGETS ${PROJECT_NAME}
     DESTINATION ${PostgreSQL_PKGLIBDIR})
