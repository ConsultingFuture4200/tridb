@@ -4,6 +4,18 @@
 cmake_minimum_required(VERSION 3.14.0)
 project(vectordb VERSION 0.1.0)
 
+# TRIDB(DEV-1228): WITH_SPTAG gate — see ADR-0004. hnswlib is the v1 vector backend and the
+# HNSW/pase_hnsw AMs carry zero SPTAG dependency; the sptag/spann AMs are the only SPTAG
+# consumers. SPTAG is x86-assuming (the GX10 ARM blocker), so default it OFF: the default build
+# compiles+links no SPTAG. Opt in with -DWITH_SPTAG=ON to build the sptag/spann AMs.
+option(WITH_SPTAG "Build the SPTAG-backed sptag/spann index AMs (default OFF; hnswlib-only otherwise)" OFF)
+if(WITH_SPTAG)
+    add_compile_definitions(WITH_SPTAG)
+    message(STATUS "vectordb: WITH_SPTAG=ON — building sptag + spann AMs (SPTAG)")
+else()
+    message(STATUS "vectordb: WITH_SPTAG=OFF — hnswlib-only build, no SPTAG (ADR-0004 / DEV-1228)")
+endif()
+
 # Find Dependency
 
 set(PostgreSQL_ADDITIONAL_VERSIONS "13")
@@ -21,6 +33,19 @@ set(EXT_SQL_FILES
 list (GET EXT_SQL_FILES 0 EXT_SQL_MAIN)
 configure_file(${EXT_CONTROL_FILE}.in ${EXT_CONTROL_FILE})
 
+# TRIDB(DEV-1228): assemble the installed extension SQL = base (hnswlib AMs) plus the SPTAG
+# fragment only when WITH_SPTAG. The default build emits no sptag/spann DDL, so CREATE EXTENSION
+# resolves no SPTAG handler symbols. See ADR-0004.
+# NOTE: this runs at configure (cmake) time, not build (make) time — toggling WITH_SPTAG requires
+# re-running cmake to regenerate the .sql, not just `make`.
+set(EXT_SQL_INSTALLED "${CMAKE_CURRENT_BINARY_DIR}/${PROJECT_NAME}--${PROJECT_VERSION}.sql")
+file(READ "${CMAKE_CURRENT_SOURCE_DIR}/${EXT_SQL_MAIN}" _tridb_sql_base)
+file(WRITE "${EXT_SQL_INSTALLED}" "${_tridb_sql_base}")
+if(WITH_SPTAG)
+    file(READ "${CMAKE_CURRENT_SOURCE_DIR}/sql/${PROJECT_NAME}_sptag.sql" _tridb_sql_sptag)
+    file(APPEND "${EXT_SQL_INSTALLED}" "\n${_tridb_sql_sptag}")
+endif()
+
 # Add Dependency
 
 #Include(FetchContent)
