# Copy to .env and fill in. Documents every env var TriDB tooling consumes.
# NO real values here — this file is committed (see .gitignore negation).

# --- Baseline / harness Postgres (baseline/harness.py) ---
PGHOST=localhost
# baseline Postgres maps to 5433 on some boxes — make sm2 needs PGPORT=5433 there
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=postgres

# --- Baseline docker-compose (baseline/docker-compose.yml) ---
BASELINE_PG_PORT=5433
NEO4J_AUTH=neo4j/password

# --- GraphRAG QA benchmark (bench/graphrag_report.py, scripts/bench_graphrag.sh) ---
# optional — enables the LLM reader in make graphrag
ANTHROPIC_API_KEY=
