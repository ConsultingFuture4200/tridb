# Copy to .env and fill in. Documents every env var TriDB tooling consumes.
# NO real values here — this file is committed (see .gitignore negation).

# --- Baseline / harness Postgres (baseline/harness.py) ---
PGHOST=localhost
# baseline Postgres maps to 5433 on some boxes — make sm2 needs PGPORT=5433 there
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=postgres

# --- Baseline docker-compose (baseline/docker-compose.yml) ---
BASELINE_PG_PORT=5433
NEO4J_AUTH=neo4j/password
# Host interface for ALL published baseline ports (neo4j/minio/milvus/postgres).
# Empty/unset = 127.0.0.1 (loopback, the safe default). Set to 0.0.0.0 only for
# deliberate remote exposure — replace the dev credentials and firewall the host first.
BASELINE_BIND=

# --- GraphRAG QA benchmark (bench/graphrag_report.py, scripts/bench_graphrag.sh) ---
# optional — enables the LLM reader in make graphrag
ANTHROPIC_API_KEY=

# --- Wiki engine serve (scripts/wiki_engine_serve.sh, bench/wiki_h2h_vecrun.py, bench/wiki_fusion.py) ---
# advisor 044: the served engine's published TCP port requires a password (generated per run into
# $OUT/pg_password by the serve script). Point harnesses at it here, or read the file directly.
TRIDB_ENGINE_PGPASSWORD=
# set to 0.0.0.0 only for an explicit shared-lab timer-parity run; default is 127.0.0.1 (loopback)
TRIDB_SERVE_BIND=
